body {
    padding: 0;
}

.setting-row {
    padding: 1dp 6dp;
}

.prop-label {
    min-width: 16dp;
}

.info-row {
    padding: 2dp 6dp;
}

.info-label {
    font-size: 13dp;
    color: #cdd6f4;
}

.info-sublabel {
    font-size: 12dp;
    color: #a6adc8;
    margin-left: 8dp;
}

.axis-label {
    font-size: 12dp;
    color: #a6adc8;
    padding: 2dp 6dp 0;
}

.scale-separator {
    margin-top: 4dp;
    padding-top: 4dp;
    border-top-width: 1dp;
    border-color: rgba(88, 91, 112, 77);
}
